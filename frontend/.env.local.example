# Copy this file to .env.local and fill in real values.
# See README.md "Connecting a real Gmail account" for the full setup steps.

# From Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# The base URL NextAuth uses for callbacks. Must match an authorized
# redirect URI in Google Cloud (that URI is this value + /api/auth/callback/google).
NEXTAUTH_URL=http://localhost:3000

# Any long random string - used to sign session JWTs.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-secret
